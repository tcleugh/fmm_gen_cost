# polymatch synthetic test fixtures (regenerated by polymatch_test at runtime from
# GDAL OGR; Python equivalent in test/generate_polymatch_test_data.py is the
# offline source). Exempts test/data/polymatch/real_example_area/ which holds
# the committed real-area shapefiles + the deterministic trips.csv consumed by
# specs/002-real-network-validation.
test/data/polymatch/*
!test/data/polymatch/real_example_area/
# Per-test transient CSVs that the [real_network] suite writes for inspection.
test/data/polymatch/real_example_area/_*.csv

